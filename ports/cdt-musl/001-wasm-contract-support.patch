-		pthread_attr_setdetachstate(&a, PTHREAD_CREATE_DETACHED);
-		sigfillset(&set);
-		pthread_sigmask(SIG_BLOCK, &set, &set);
-		if (pthread_create(&td, &a, wait_thread, st)) {
-			free(st);
-			errno = EAGAIN;
-			return -1;
-		}
-		pthread_sigmask(SIG_SETMASK, &set, 0);
-	}
-
-	return 0;
-}
-
-LFS64(lio_listio);
