-		case LIO_WRITE:
-			ret = aio_write(cbs[i]);
-			break;
-		default:
-			continue;
-		}
-		if (ret) {
-			free(st);
-			errno = EAGAIN;
-			return -1;
-		}
-	}
-
-	if (mode == LIO_WAIT) {
