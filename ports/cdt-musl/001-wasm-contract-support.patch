-			            action?"\nTO FIX: ":"",
-			            action?action:"", action?" ":"",
-			            tag?tag:"" )<1)
-				ret = MM_NOCON;
-			close(consolefd);
-		}
-	}
-
-	if (classification & MM_PRINT) {
-		while (cmsg && cmsg[0]) {
-			for(i=0; msgs[i]; i++) {
-				if (!_strcolcmp(msgs[i], cmsg)) break;
