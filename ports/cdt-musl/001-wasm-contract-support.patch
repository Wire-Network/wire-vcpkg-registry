-
-	if (cnt < 0) {
-		errno = EINVAL;
-		return -1;
-	}
-
-	if (mode == LIO_WAIT || (sev && sev->sigev_notify != SIGEV_NONE)) {
-		if (!(st = malloc(sizeof *st + cnt*sizeof *cbs))) {
-			errno = EAGAIN;
-			return -1;
-		}
-		st->cnt = cnt;
-		st->sev = sev;
